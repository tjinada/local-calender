# Google OAuth2 (from GCP Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/auth/callback

# OpenWeatherMap
WEATHER_API_KEY=
WEATHER_LOCATION=Toronto,CA

# VAPID Push Notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# App
PORT=3000
NODE_ENV=development
DATA_DIR=./data
